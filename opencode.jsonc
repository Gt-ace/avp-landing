{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "edit": "allow",
        "skill": {
            "using-superpowers": "allow",
            "brainstorming": "allow",
            "test-driven-development": "allow",
            "systematic-debugging": "allow",
            "verification-before-completion": "allow",
            "writing-plans": "allow",
            "writing-skills": "allow",
            "executing-plans": "allow",
            "subagent-driven-development": "allow",
            "dispatching-parallel-agents": "allow",
            "using-git-worktrees": "allow",
            "requesting-code-review": "allow",
            "receiving-code-review": "allow",
            "finishing-a-development-branch": "allow",
            "avp-context": "allow",
            "avp-design-stack": "allow",
            "design-motion-principles": "allow",
            "design-taste-frontend": "allow",
            "frontend-design": "allow",
            "high-end-visual-design": "allow",
            "ckm:design": "allow",
            "ckm:design-system": "allow",
            "ckm:ui-styling": "allow",
            "ckm:brand": "allow",
            "brandkit": "allow",
            "imagegen-frontend-web": "allow",
            "image-to-code": "allow",
            "redesign-existing-projects": "allow",
            "gpt-taste": "allow",
            "full-output-enforcement": "allow",
            "humanizer": "ask",
            "customize-opencode": "ask",
            "graphify": "deny",
            "*": "ask",
        },
    },
}
