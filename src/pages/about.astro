---
import BaseLayout from '../layouts/BaseLayout.astro'
import LogoMarquee from '../components/LogoMarquee.astro'
---
<BaseLayout title="About | AVP Software">
  <main class="page-container">
    <span class="page-label">About</span>
    <h1 class="page-heading">Arthur Van Petegem</h1>
    <div class="page-body">
      <p>
        Arthur Van Petegem is a software engineer and builder based in St. Gallen and Baden, Aargau.
        He builds precise, opinionated software, from volunteer coordination platforms
        to automating operations processes.
      </p>
      <p>
        AVP Software is the studio through which that work ships. The focus is on
        craft over convention: software that is fast, considered, and owned by the
        people who use it.
      </p>
    </div>

      <ul class="about-focus">
        <li><span class="label">Focus</span>Web platforms</li>
        <li><span class="label">Focus</span>Process automations</li>
        <li><span class="label">Focus</span>AI-assisted products</li>
      </ul>
  </main>
  <LogoMarquee />
</BaseLayout>

<style>
  .about-focus {
    list-style: none;
    margin-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .about-focus li {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-ink);
  }

  .about-focus .label {
    width: 4rem;
    flex-shrink: 0;
  }
</style>
