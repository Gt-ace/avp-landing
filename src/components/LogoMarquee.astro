---
interface Props {
  label?: string
}
const { label = 'Built with' } = Astro.props

interface Logo {
  src: string
  alt: string
  /** Optional box width override in px for wide wordmarks. Defaults to 132. */
  w?: number
}

const logos: Logo[] = [
  { src: '/logos/claude-code.svg', alt: 'Claude Code' },
  { src: '/logos/ts-logo-512.svg', alt: 'TypeScript' },
  { src: '/logos/Svelte_Logo.svg', alt: 'Svelte' },
  { src: '/logos/docker-svgrepo-com.svg', alt: 'Docker' },
  { src: '/logos/cloudflare-icon.svg', alt: 'Cloudflare' },
  { src: '/logos/hetzner-h.svg', alt: 'Hetzner' },
  { src: '/logos/drizzle-mono.svg', alt: 'Drizzle' },
  { src: '/logos/opencode-wordmark-dark.svg', alt: 'opencode', w: 168 },
  { src: '/logos/n8n.svg', alt: 'n8n', w: 168 },
  { src: '/logos/better-auth.svg', alt: 'Better Auth', w: 168 },
  { src: '/logos/git.svg', alt: 'Git' },
  { src: '/logos/github.svg', alt: 'GitHub' },
]
---
<section class="logo-marquee-wrap" aria-label={label}>
  <span class="logo-marquee-label">{label}</span>
  <div class="logo-marquee">
    <div class="logo-track">
      {[0, 1].map((setIndex) => (
        <div class="logo-set" aria-hidden={setIndex === 1 ? 'true' : undefined}>
          {logos.map((logo) => (
            <span class="logo-item" style={logo.w ? `width:${logo.w}px` : undefined}>
              <img src={logo.src} alt={logo.alt} loading="eager" decoding="async" />
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .logo-marquee-wrap {
    margin-top: 3rem;
  }

  .logo-marquee-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .logo-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .logo-track {
    display: flex;
    width: max-content;
    animation: logo-scroll 32s linear infinite;
  }

  .logo-set {
    display: flex;
    flex: 0 0 auto;
    gap: 1.5rem;
    padding-right: 1.5rem;
  }

  .logo-item {
    flex: 0 0 auto;
    width: 132px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-item img {
    max-width: 85%;
    max-height: 80%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  @keyframes logo-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
